# Grays Park Masjid — environment variables reference
#
# Copy this file to `.env` for local tooling (drizzle-kit, seed script) and/or
# configure the same variables in Coolify's environment settings for each
# service. Do not commit a real `.env` file.

# --- Shared / database -------------------------------------------------
# Postgres connection string used by the API server and by lib/db tooling
# (drizzle-kit push, seed script).
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/grays_park_masjid

# --- API server (artifacts/api-server) ---------------------------------
# Port the API server listens on inside its container.
PORT=8080
NODE_ENV=production

# Secret used to sign session/auth JWTs. Generate a long random string, e.g.
# `openssl rand -hex 32`. Must stay constant across restarts/deploys or
# existing sessions will be invalidated.
JWT_SECRET=change-me-to-a-long-random-string

# Public base URL of the deployed website, used to build links in emails
# (e.g. password reset links). Example: https://masjid.example.com
APP_BASE_URL=https://your-domain.example.com

# Log verbosity (optional, defaults to "info"). One of: fatal, error, warn,
# info, debug, trace.
LOG_LEVEL=info

# Outbound email (password reset, enquiry notifications, etc.). Any SMTP
# provider works (e.g. self-hosted Postfix, SendGrid, Mailgun, Amazon SES SMTP).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=smtp-username
SMTP_PASS=smtp-password
MAIL_FROM=no-reply@your-domain.example.com

# --- Object storage (file/PDF uploads: timetables, gallery, staff photos) --
# IMPORTANT: the current implementation authenticates to Google Cloud Storage
# via Replit's built-in sidecar credential broker, which only exists inside
# the Replit environment. It will NOT work as-is on Coolify or any other
# host. Before deploying off Replit, swap `artifacts/api-server/src/lib/objectStorage.ts`
# to authenticate with a real GCS service-account key (or migrate to S3-compatible
# storage) and wire the corresponding credentials in here. Until that change is
# made, file upload features (timetable PDFs, gallery photos, staff photos)
# will not function in a non-Replit deployment.
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PRIVATE_OBJECT_DIR=
PUBLIC_OBJECT_SEARCH_PATHS=

# --- Website (artifacts/website) ----------------------------------------
# These only affect the Vite production build (Dockerfile.website build args),
# not the running container. Leave as defaults unless hosting under a
# sub-path instead of the domain root.
BASE_PATH=/
